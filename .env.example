# App
NODE_ENV=development
PORT=3000
APP_NAME=payment-provider

# Database (DB_PASSWORD must match your PostgreSQL user — default below matches docker-compose.yml)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=payment_provider

# JWT
JWT_SECRET=your_super_secret_key_min_32_chars_long_string_here
JWT_EXPIRY=15m

# Encryption (PCI-DSS: must be 256-bit, 32 bytes hex = 64 chars)
CARD_ENCRYPTION_KEY=your_256_bit_encryption_key_here_minimum_32_chars

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Optional: when set, GET /metrics requires header `X-Metrics-Key: <value>` or `Authorization: Bearer <value>`
# METRICS_API_KEY=

# CORS
ALLOWED_ORIGINS=http://localhost:3000
